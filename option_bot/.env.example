# 复制为项目根目录 .env 后填写。切勿提交真实 .env / 私钥到 git。

# ---- 券商凭证（SDK 读取，首期用模拟盘 paper account）----
TIGEROPEN_TIGER_ID=
TIGEROPEN_ACCOUNT=
# 私钥：可填内容，或填容器内路径（建议放 /app/data 并在此填路径）
TIGEROPEN_PRIVATE_KEY=/app/data/rsa_private_key.pem

# ---- 看板（必填，否则不启动）----
OBOT_WEB_USER=admin
OBOT_WEB_PASSWORD=change-me-please
OBOT_WEB_HOST=0.0.0.0
OBOT_WEB_PORT=8000

# ---- 操作面（apikey；不填则不启动操作面）----
OBOT_OPS_API_KEY=
OBOT_OPS_PORT=8001
# 默认 false=操作面仅容器内本机可达；true 才绑 0.0.0.0 对外
OBOT_OPS_EXPOSE=false

# ---- 策略参数 ----
OBOT_TP=30
OBOT_SL=50
OBOT_CLOSE_BUFFER=5
OBOT_POLL_INTERVAL=2
OBOT_MAX_QTY=1
# 市价单允许的最大相对点差%(超过则拒单防滑点)；流动性差/盘前可调大，如 20
OBOT_MAX_SPREAD=5
# 平仓策略：threshold(固定止盈) / trailing(移动止盈) / breakeven(保本) /
#          time_in_trade(时长上限) / bracket(可组合，下面各组件值>0即启用)
OBOT_STRATEGY=threshold
# trailing/bracket：涨破 activation% 武装，从峰值回撤 giveback 个点即平仓锁盈
OBOT_TRAIL_ACTIVATION=20
OBOT_TRAIL_GIVEBACK=10
# breakeven/bracket：盈利冲过 activation% 武装，回吐到 lock%(0=成本价)即平。bracket 中 0=关闭
OBOT_BREAKEVEN_ACTIVATION=0
OBOT_BREAKEVEN_LOCK=0
# 持仓时长上限(分钟)；bracket 中 0=关闭
OBOT_MAX_HOLD_MINUTES=0
# 说明：bracket 各组件优先级 时间强平>硬止损>保本>移动止盈>固定止盈(OBOT_TP)>时长
# 半日市收盘表 JSON 路径（可选），如 /app/data/early_close.json
OBOT_EARLY_CLOSE_FILE=

# ---- 持久化 ----
OBOT_DB_FILE=/app/data/option_bot.db
OBOT_STATE_FILE=/app/data/option_bot_state.json
# 逐tick持仓走势的保留天数（超过则定期清理，控制表增长）
OBOT_TICK_RETENTION_DAYS=7

# ---- 容器启动是否自动开仓（默认 false，安全）----
OBOT_OPEN_ON_START=false
# 实盘账户(is_paper=False)默认禁止自动开仓；确需实盘自动开仓才设为 true（危险，真实下单）
OBOT_ALLOW_LIVE_AUTO_OPEN=false
OBOT_SYMBOL=
OBOT_DIRECTION=
OBOT_EXPIRY=
OBOT_STRIKE=
OBOT_QTY=1
