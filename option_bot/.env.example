# 复制为项目根目录 .env 后填写。切勿提交真实 .env / 私钥到 git。

# ---- 券商凭证（SDK 读取，首期用模拟盘 paper account）----
TIGEROPEN_TIGER_ID=
TIGEROPEN_ACCOUNT=
# 私钥：可填内容，或填容器内路径（建议放 /app/data 并在此填路径）
TIGEROPEN_PRIVATE_KEY=/app/data/rsa_private_key.pem

# ---- 看板（必填，否则不启动）----
OBOT_WEB_USER=admin
OBOT_WEB_PASSWORD=change-me-please
OBOT_WEB_HOST=0.0.0.0
OBOT_WEB_PORT=8000

# ---- 操作面（apikey；不填则不启动操作面）----
OBOT_OPS_API_KEY=
OBOT_OPS_PORT=8001
# 默认 false=操作面仅容器内本机可达；true 才绑 0.0.0.0 对外
OBOT_OPS_EXPOSE=false

# ---- 策略参数 ----
OBOT_TP=30
OBOT_SL=50
OBOT_CLOSE_BUFFER=5
# 收盘前强平仅作用于 DTE≤该值的期权(0/1=临近到期当日平)；DTE 更大的多日期权持有过夜。
# 过夜代价：盘后市价单不成交、行情可能失真、隔夜跳空风险自负。默认 1。
OBOT_EOD_CLOSE_MAX_DTE=1
# 当日已实现亏损达此美元数即停止当日开仓(kill switch，只挡开仓不平已有仓)；0=关闭。
OBOT_DAILY_LOSS_LIMIT=300
OBOT_POLL_INTERVAL=2
OBOT_MAX_QTY=1
# 市价单允许的最大相对点差%(超过则拒单防滑点)；流动性差/盘前可调大，如 20
OBOT_MAX_SPREAD=5
# 平仓策略：threshold(固定止盈) / trailing(移动止盈) / breakeven(保本) /
#          time_in_trade(时长上限) / bracket(可组合，下面各组件值>0即启用)
OBOT_STRATEGY=threshold
# trailing/bracket：涨破 activation% 武装，从峰值回撤 giveback 个点(绝对)即平仓锁盈
OBOT_TRAIL_ACTIVATION=20
OBOT_TRAIL_GIVEBACK=10
# 相对比例回撤(混合)：仅当峰值盈利≥THRESHOLD% 时启用，回撤阈值取 max(GIVEBACK, 峰值×RATIO%)
# RATIO=0 关闭(纯绝对)。例 RATIO=20,THRESHOLD=50：峰值+200%→回撤max(10,40)=40→跌回+160%平
OBOT_TRAIL_RELATIVE_RATIO=0
OBOT_TRAIL_RELATIVE_THRESHOLD=50
# breakeven/bracket：盈利冲过 activation% 武装，回吐到 lock%(0=成本价)即平。bracket 中 0=关闭
OBOT_BREAKEVEN_ACTIVATION=0
OBOT_BREAKEVEN_LOCK=0
# 持仓时长上限(分钟)；bracket 中 0=关闭
OBOT_MAX_HOLD_MINUTES=0
# 说明：bracket 各组件优先级 时间强平>硬止损>保本>移动止盈>固定止盈(OBOT_TP)>时长

# ---- 双向跨式(straddle)多腿模式 ----
# single(单腿,默认) / straddle(同行权价买 call+put 双腿) / condor(铁鹰卖方)
OBOT_MODE=single

# ---- 铁鹰(condor)卖方模式：IV择时 + 定义风险双垂直信用价差 + 人工确认开仓 ----
# 设计 docs/design/2026-06-26-condor-premium-selling-engine.md；策略手册 docs/strategy/...
# 自动:IV高才产出开仓提案、止盈(50%)/止损(2×)/到期前(21DTE)自动平仓;开仓须人工 ops approve。
# ⚠️ combo 净价/动作约定须先在 paper 验证;默认请用 paper 账户跑通再考虑实盘。
OBOT_CONDOR_UNDERLYING=SPY          # SPY / QQQ
OBOT_CONDOR_TARGET_DTE=40           # 目标到期天数(30~45)
OBOT_CONDOR_SHORT_DELTA=0.16        # 短腿目标|delta|(~1σ价外)
OBOT_CONDOR_WING_WIDTH=5            # 翼宽(行权价美元间距)
OBOT_CONDOR_MIN_IV=0.20             # IV入场闸:ATM隐含波动率绝对下限(低于不开)
OBOT_CONDOR_PROFIT_TARGET=0.5       # 止盈:吃满50%权利金平
OBOT_CONDOR_STOP_MULT=2.0           # 止损:亏达2×权利金平
OBOT_CONDOR_DTE_EXIT=21             # 到期前N天平(避gamma)
OBOT_CONDOR_MAX_LOSS_PCT=0.05       # 单仓最大亏损占账户比例(定张数)
OBOT_CONDOR_ACCOUNT_EQUITY=0        # 账户净值(>0按风险定张数;0回退OBOT_MAX_QTY)
OBOT_CONDOR_PROPOSAL_TTL_MIN=10     # 开仓提案有效期(分钟),过期作废重评
# 券商行情无逐档 delta 时(如某些 paper 账户)按 BS 自算:平价反推现价+briefs平值IV/利率
OBOT_CONDOR_SYNTHETIC_GREEKS=true   # 自动检测券商无 delta 时启用;false=只用券商 greeks
OBOT_CONDOR_RISK_FREE=0             # 合成 delta 用无风险利率;0=用 briefs rates_bonds,>0 覆盖
# 开仓单类型:CUSTOM=单笔4腿原子单(避免两垂直间半成交,默认) / VERTICAL=两个垂直(回退)
OBOT_CONDOR_OPEN_COMBO_TYPE=CUSTOM
# 确认开仓:容器内 curl -XPOST 127.0.0.1:8001/ops/approve (或 /ops/reject),需 apikey
# 单腿止损%：某腿亏到即平该腿(让市场筛出赢家方向)
OBOT_STRADDLE_LEG_STOP=10
# 组合止盈方式：fixed(固定%) / trailing(移动,吃大波动,默认)
OBOT_STRADDLE_TP_MODE=trailing
OBOT_STRADDLE_TP=10                 # fixed: 组合盈亏达总成本×% 即平全部
OBOT_STRADDLE_TRAIL_ACTIVATION=10   # trailing: 组合武装阈值%
OBOT_STRADDLE_TRAIL_GIVEBACK=10     # trailing: 组合从峰值回撤%
# straddle 开仓只需 OBOT_SYMBOL/EXPIRY/STRIKE/QTY(无需 DIRECTION，自动 call+put)
# 退出优先级：时间强平 > 组合止盈 > 腿止损（无硬止损）
# 半日市收盘表 JSON 路径（可选），如 /app/data/early_close.json
OBOT_EARLY_CLOSE_FILE=

# ---- 持久化 ----
OBOT_DB_FILE=/app/data/option_bot.db
OBOT_STATE_FILE=/app/data/option_bot_state.json
# 逐tick持仓走势的保留天数（超过则定期清理，控制表增长）
OBOT_TICK_RETENTION_DAYS=7

# ---- 容器启动是否自动开仓（默认 false，安全）----
OBOT_OPEN_ON_START=false
# 实盘账户(is_paper=False)默认禁止自动开仓；确需实盘自动开仓才设为 true（危险，真实下单）
OBOT_ALLOW_LIVE_AUTO_OPEN=false
OBOT_SYMBOL=
OBOT_DIRECTION=
OBOT_EXPIRY=
OBOT_STRIKE=
OBOT_QTY=1
